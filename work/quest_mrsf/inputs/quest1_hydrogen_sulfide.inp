# QUEST1 hydrogen_sulfide: triplet-reference MRSF-TDDFT
# Generated by quest1.py. Run from this directory with:
#   openqp inputs/quest1_hydrogen_sulfide.inp
#
# Reference: [scf] type=rohf, multiplicity=3
# Target roots: [tdhf] type=mrsf, multiplicity=1

[input]
system=geometries/hydrogen_sulfide.xyz
charge=0
runtype=energy
basis=aug-cc-pvtz
functional=bhhlyp
method=tdhf
d4=False

[guess]
type=huckel
save_mol=False

[scf]
type=rohf
multiplicity=3
maxit=30
maxdiis=5
conv=1.0e-8
save_molden=False

[dftgrid]
rad_npts=96
ang_npts=302
pruned=

[tdhf]
type=mrsf
multiplicity=1
nstate=10
maxit=30
conv=1.0e-8
zvconv=1.0e-8
